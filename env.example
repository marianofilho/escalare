# .env.example
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA comite o arquivo .env — apenas este .env.example.

# ─── Banco de dados (Prisma) ─────────────────────────────────────────────────
# Encontre em: Supabase → Project Settings → Database → Connection string
#
# DATABASE_URL usa o connection pooler (porta 6543) — usado pelo Prisma em runtime
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL usa a conexão direta (porta 5432) — usado pelo Prisma para migrations
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase (público — acessível no browser) ───────────────────────────────
# Encontre em: Supabase → Project Settings → API → Project URL e anon key
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ─── Supabase (privado — apenas no servidor) ─────────────────────────────────
# Encontre em: Supabase → Project Settings → API → service_role key
# ATENÇÃO: nunca exponha esta chave no frontend
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
